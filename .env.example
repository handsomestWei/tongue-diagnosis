# 复制为 .env 后按需修改

JWT_SECRET_KEY=change-me-in-production-use-long-random-string
DATABASE_URL=sqlite:///./data/app.db
STORAGE_ROOT=./storage

# 开发：启动时建表并种子演示用户（生产请 false）
AUTO_CREATE_TABLES=true
SEED_DEMO_USERS=true

# YOLO 分类权重（存在且可读时 POST /api/v1/infer 将真实推理）
CLASSIFY_WEIGHTS_PATH=

# TongueSAM 根目录（full_face_selfie 时子进程跑 predict.py）
TONGUESAM_ROOT=./tongue_sam

INFER_DEVICE=cpu
INFER_IMGSZ=224
INFER_SAM_TIMEOUT_SEC=600

# P3 训练工作目录与 device（与 INFER 可同设 cpu）
TRAIN_WORK_ROOT=./storage/train_work
TRAIN_DEVICE=cpu

